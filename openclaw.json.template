{
  "gateway": {
    "port": 18789,
    "auth": {
      "mode": "none"
    }
  },
  "models": {
    "providers": {
      "portkey": {
        "baseUrl": "https://api.portkey.ai/v1",
        "apiKey": "${PORTKEY_API_KEY}",
        "api": "openai-completions",
        "request": {
          "headers": {
            "x-portkey-api-key": "${PORTKEY_API_KEY}",
            "x-portkey-config": "${PORTKEY_CONFIG}"
          }
        },
        "models": [
          {
            "id": "gemini-3.5-flash",
            "name": "Gemini 3.5 Flash via Portkey",
            "reasoning": false,
            "input": ["text", "image"],
            "contextWindow": 1000000,
            "maxTokens": 64000
          },
          {
            "id": "gemini-2.5-flash",
            "name": "Gemini 2.5 Flash via Portkey",
            "reasoning": false,
            "input": ["text", "image"],
            "contextWindow": 1000000,
            "maxTokens": 64000
          },
          {
            "id": "gemini-2.5-pro",
            "name": "Gemini 2.5 Pro via Portkey",
            "reasoning": true,
            "input": ["text", "image"],
            "contextWindow": 1000000,
            "maxTokens": 64000
          }
        ]
      }
    }
  },
  "agents": {
    "defaults": {
      "model": {
        "primary": "portkey/gemini-3.5-flash"
      }
    }
  },
  "channels": {
    "telegram": {
      "bots": [
        {
          "name": "default",
          "token": "${TELEGRAM_BOT_TOKEN}",
          "allowFrom": [YOUR_TELEGRAM_CHAT_ID],
          "dmPolicy": "allowlist"
        }
      ]
    }
  }
}
